{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "Deploys the WSM eSign PDF service as an Azure Container App (Consumption). Pulls a prebuilt public image and exposes an HTTPS endpoint authenticated by an API key. No source build required."
  },
  "parameters": {
    "appName": {
      "type": "string",
      "defaultValue": "wsm-esign-api",
      "metadata": { "description": "Name for the Container App and its resources." }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": { "description": "Azure region. Choose one near your Salesforce instance." }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "ghcr.io/jcd386/wsm-esign-api:v1",
      "metadata": { "description": "Public container image to deploy. Leave as default unless you host your own copy." }
    },
    "esignApiKey": {
      "type": "securestring",
      "defaultValue": "[newGuid()]",
      "metadata": { "description": "Shared secret. Salesforce sends this as the X-API-Key header. A random key is generated if left blank; copy it from the deployment outputs." }
    },
    "cpuCores": {
      "type": "string",
      "defaultValue": "1.0",
      "allowedValues": [ "0.5", "1.0", "1.5", "2.0" ],
      "metadata": { "description": "vCPU per replica. Memory is paired automatically (2 GiB per vCPU)." }
    },
    "minReplicas": {
      "type": "int",
      "defaultValue": 1,
      "minValue": 0,
      "maxValue": 5,
      "metadata": { "description": "Minimum replicas. 1 = always warm (no cold start, recommended). 0 = scale to zero (cheapest, ~10-30s cold start on first call after idle)." }
    },
    "maxReplicas": {
      "type": "int",
      "defaultValue": 5,
      "minValue": 1,
      "maxValue": 30,
      "metadata": { "description": "Maximum replicas to scale out to under load." }
    }
  },
  "variables": {
    "lawName": "[concat(parameters('appName'), '-logs')]",
    "envName": "[concat(parameters('appName'), '-env')]",
    "memoryMap": {
      "0.5": "1.0Gi",
      "1.0": "2.0Gi",
      "1.5": "3.0Gi",
      "2.0": "4.0Gi"
    }
  },
  "resources": [
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2022-10-01",
      "name": "[variables('lawName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "name": "PerGB2018" },
        "retentionInDays": 30,
        "features": { "searchVersion": 1 }
      }
    },
    {
      "type": "Microsoft.App/managedEnvironments",
      "apiVersion": "2024-03-01",
      "name": "[variables('envName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]"
      ],
      "properties": {
        "appLogsConfiguration": {
          "destination": "log-analytics",
          "logAnalyticsConfiguration": {
            "customerId": "[reference(resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName')), '2022-10-01').customerId]",
            "sharedKey": "[listKeys(resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName')), '2022-10-01').primarySharedKey]"
          }
        }
      }
    },
    {
      "type": "Microsoft.App/containerApps",
      "apiVersion": "2024-03-01",
      "name": "[parameters('appName')]",
      "location": "[parameters('location')]",
      "dependsOn": [
        "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]"
      ],
      "properties": {
        "managedEnvironmentId": "[resourceId('Microsoft.App/managedEnvironments', variables('envName'))]",
        "configuration": {
          "activeRevisionsMode": "Single",
          "ingress": {
            "external": true,
            "targetPort": 8000,
            "transport": "auto",
            "allowInsecure": false,
            "traffic": [ { "latestRevision": true, "weight": 100 } ]
          },
          "secrets": [
            { "name": "esign-api-key", "value": "[parameters('esignApiKey')]" }
          ]
        },
        "template": {
          "containers": [
            {
              "name": "[parameters('appName')]",
              "image": "[parameters('containerImage')]",
              "resources": {
                "cpu": "[json(parameters('cpuCores'))]",
                "memory": "[variables('memoryMap')[parameters('cpuCores')]]"
              },
              "env": [
                { "name": "ESIGN_API_KEY", "secretRef": "esign-api-key" }
              ],
              "probes": [
                {
                  "type": "Liveness",
                  "httpGet": { "path": "/health", "port": 8000 },
                  "initialDelaySeconds": 10,
                  "periodSeconds": 30
                },
                {
                  "type": "Readiness",
                  "httpGet": { "path": "/health", "port": 8000 },
                  "initialDelaySeconds": 5,
                  "periodSeconds": 10
                }
              ]
            }
          ],
          "scale": {
            "minReplicas": "[parameters('minReplicas')]",
            "maxReplicas": "[parameters('maxReplicas')]",
            "rules": [
              {
                "name": "http-scale",
                "http": { "metadata": { "concurrentRequests": "10" } }
              }
            ]
          }
        }
      }
    }
  ],
  "outputs": {
    "endpointUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01').configuration.ingress.fqdn)]"
    },
    "healthCheckUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01').configuration.ingress.fqdn, '/health')]"
    },
    "apiKey": {
      "type": "string",
      "value": "[parameters('esignApiKey')]"
    },
    "salesforceNamedCredentialUrl": {
      "type": "string",
      "value": "[concat('https://', reference(resourceId('Microsoft.App/containerApps', parameters('appName')), '2024-03-01').configuration.ingress.fqdn)]"
    }
  }
}
